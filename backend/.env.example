DATABASE_URL=sqlite:///./data/app.db
# MySQL 须使用同步驱动 pymysql（不要用 asyncmy）：
# DATABASE_URL=mysql+pymysql://user:pass@127.0.0.1:3306/vote
JWT_SECRET=change-me
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# 助力结束后收集 assist_commit 的宽限秒数（默认 1）
# ASSIST_GRACE_SECONDS=1
# 管理控制台默认账号（生产环境务必修改）
# ADMIN_CONSOLE_USERNAME=admin
# ADMIN_CONSOLE_PASSWORD=admin
